# Keep only the top-level data folder structure in Git.
# data/**
# !data/
# !data/01_raw/
# !data/02_processed/
# !data/03_split/
# !data/01_raw/.gitkeep
# !data/02_processed/.gitkeep
# !data/03_split/.gitkeep
data/01_raw/avocado/*
data/01_raw/strawberry/*
data/03_split/avocado/*
data/03_split/strawberry/*
data/02_processed/strawberry/*
data/02_processed/avocado/*
data/outputs/avocado/*
data/outputs/strawberry/*
# Runtime logs and private stage journals.
logs/**

# Python runtime/cache artifacts.
__pycache__/
**/__pycache__/
*.py[cod]

# Local model artifacts can be large and machine-specific.
models/**/*.pth
models/**/*.pt
models/strawberry/model_A/*
models/strawberry/model_B/*
models/strawberry/model_C/*
models/strawberry/model_D/*

# Stale root-level Stage 1.5 reports from before sample/full output split.
output/reports/stage_1_5/image_inventory_summary.md
output/reports/stage_1_5/stage_1_5_run_debug.json

# Local avocado U2Net tuning and smoke-test artifacts.
output/u2net_avocado_*/
output/reports/avocado_full_test_smoke*/
output/reports/processed/u2net_avocado_*/
output/reports/processed/*_smoke*/
data/02_processed/*_smoke*/

# Ignore the local virtual environment folder.
.venv/
venv/
env/
